{
  "name": "bookshelfai",
  "private": true,
  "type": "module",
  "description": "BookshelfAi monorepo — backend (Express) + client (Vite/React)",
  "workspaces": [
    "backend",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,magenta \"npm run dev -w backend\" \"npm run dev -w client\"",
    "dev:api": "npm run dev -w backend",
    "dev:web": "npm run dev -w client",
    "start": "npm run start -w backend",
    "build": "npm run build -w client",
    "build:web": "npm run build -w client",
    "verify": "node scripts/verify-env.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
