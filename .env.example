# Repo root `.env` — loaded by `backend/src/loadEnv.js` (and by `scripts/verify-env.mjs`).
# Layout: `backend/` = Express API · `client/` = Vite + React · `scripts/` = tooling

PORT=3000
NODE_ENV=development

# Frontend — copy `client/.env.example` → `client/.env` (or set here only for docs)
# VITE_API_URL=http://localhost:3000

# Supabase / PostgreSQL (TLS auto-enabled for remote hosts; set DATABASE_SSL=false for local Postgres without SSL)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_VISION_MODEL=gpt-4o
OPENAI_TEXT_MODEL=gpt-4o

# Upstash Redis (REST)
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# Rate limits — default (e.g. /api/users)
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=60

# Stricter limits for /api/books (scan + recommend)
RATE_LIMIT_AI_WINDOW_SECONDS=60
RATE_LIMIT_AI_MAX_REQUESTS=10

# Uploads
UPLOAD_MAX_FILE_SIZE_MB=10
MAX_IMAGE_DIMENSION=8192

# API body size for JSON
JSON_BODY_LIMIT=512kb

# Production: comma-separated frontend origins (e.g. https://app.example.com,https://www.example.com)
# CORS_ORIGIN=

# Behind Railway/Render/Fly: set to 1 so req.ip / rate limits use client IP
# TRUST_PROXY=1

# Logging
# LOG_LEVEL=info

# Recommendation cache TTL (seconds)
CACHE_TTL_SECONDS=3600
